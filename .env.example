# ============================================================================
# DATABASE - REQUIRED FOR ALL FUNCTIONALITY
# ============================================================================
# PostgreSQL connection URL - Required for all data persistence
# Format: postgresql://user:password@host:port/database
# Get from: Database provider (Vercel Postgres, Supabase, AWS RDS, etc.)
DATABASE_URL="postgresql://user:password@localhost:5432/saukimart"

# ============================================================================
# AUTHENTICATION & SECURITY - REQUIRED
# ============================================================================
# JWT signing key for access tokens (min 32 characters)
# Generate: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
JWT_SECRET="your-super-secret-jwt-key-at-least-32-characters-long"

# JWT signing key for refresh tokens (min 32 characters)
JWT_REFRESH_SECRET="your-separate-refresh-token-secret-key"

# Base URL for the application
# For localhost: http://localhost:3000
# For production: https://saukimart.online
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ============================================================================
# PAYMENT GATEWAY - FLUTTERWAVE (REQUIRED FOR WALLET TOP-UP)
# ============================================================================
# Get from: https://dashboard.flutterwave.com/settings/apis
# Public key (used in frontend for Flutterwave inline)
FLW_PUBLIC_KEY="pk_test_xxxxxxxxxxxxx"

# Secret key (used in backend for API calls)
FLW_SECRET_KEY="sk_test_xxxxxxxxxxxxx"

# Webhook hash for verifying Flutterwave webhook signatures
FLW_WEBHOOK_HASH="your-flutterwave-webhook-hash"

# Flutterwave API base URL
NEXT_PUBLIC_FLW_BASE_URL="https://api.flutterwave.com/v3"

# ============================================================================
# DATA PROVIDER - INTERSWITCH (OPTIONAL - FOR AIRTIME/DATA)
# ============================================================================
# Get from: https://developer.interswitchng.com/
# Client ID for authentication
INTERSWITCH_CLIENT_ID="your-interswitch-client-id"

# Client secret for authentication
INTERSWITCH_CLIENT_SECRET="your-interswitch-client-secret"

# Terminal ID assigned by Interswitch
INTERSWITCH_TERMINAL_ID="your-terminal-id"

# Authentication URL
INTERSWITCH_AUTH_URL="https://sandbox.interswitchng.com"

# ============================================================================
# DATA PROVIDER - AMIGO DATA (REQUIRED FOR DATA PURCHASES)
# ============================================================================
# Get from: https://amigosms.com/documentation
# API token for Amigo authentication
AMIGO_API_TOKEN="your-amigo-api-token"

# Proxy URL for Amigo requests (usually AWS Lambda proxy)
AMIGO_PROXY_URL="https://your-aws-lambda-proxy.amazonaws.com"

# ============================================================================
# FIREBASE - NOTIFICATIONS & AUTHENTICATION (OPTIONAL - FOR PUSH NOTIFICATIONS)
# ============================================================================
# Get from: Firebase Console > Project Settings > Service Accounts
# Firebase project ID
FIREBASE_PROJECT_ID="your-firebase-project-id"

# Firebase private key (from service account JSON)
# Keep in single line with \n for newlines
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBA...\n-----END PRIVATE KEY-----"

# Firebase service account email
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com"

# Frontend Firebase configuration
NEXT_PUBLIC_FIREBASE_API_KEY="AIzaSyD..."
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-firebase-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="123456789"
NEXT_PUBLIC_FIREBASE_APP_ID="1:123456789:web:abc..."
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID="G-ABC123"

# ============================================================================
# ENVIRONMENT & DEPLOYMENT
# ============================================================================
# Node environment (development or production)
NODE_ENV="production"

# Public environment indicator
NEXT_PUBLIC_ENVIRONMENT="production"

# ============================================================================
# OPTIONAL - EMAIL NOTIFICATIONS
# ============================================================================
# Email sender address
MAIL_FROM="noreply@saukimart.online"

# SMTP server host
SMTP_HOST="smtp.gmail.com"

# SMTP server port
SMTP_PORT="587"

# SMTP username
SMTP_USER="your-email@gmail.com"

# SMTP password or app password
SMTP_PASSWORD="your-app-password"

# ============================================================================
# OPTIONAL - ADMIN CONFIGURATION
# ============================================================================
# Admin email for notifications
ADMIN_EMAIL="admin@saukimart.online"

# Support email for customer inquiries
SUPPORT_EMAIL="support@saukimart.online"

# ============================================================================
# REQUIRED FOR PRODUCTION - ADD THESE TO VERCEL
# ============================================================================
# Summary of all variables needed in Vercel Environment Variables:
# 1. DATABASE_URL
# 2. JWT_SECRET
# 3. JWT_REFRESH_SECRET
# 4. NEXT_PUBLIC_BASE_URL
# 5. FLW_PUBLIC_KEY
# 6. FLW_SECRET_KEY
# 7. FLW_WEBHOOK_HASH
# 8. AMIGO_API_TOKEN
# 9. AMIGO_PROXY_URL
# 10. FIREBASE_PROJECT_ID
# 11. FIREBASE_PRIVATE_KEY
# 12. FIREBASE_CLIENT_EMAIL
# 13. (Plus all NEXT_PUBLIC_* variables for frontend)
